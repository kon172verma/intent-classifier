# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Environment files
.env
.env.*

# Type checker and test caches
.mypy_cache/
.pytest_cache/
.ruff_cache/
.pyright/

# Generated evaluation reports (re-created by running evaluations)
baseline_evaluation/reports_zero_shot/*.json
baseline_evaluation/reports_few_shot/*.json
!baseline_evaluation/reports_zero_shot/.gitkeep
!baseline_evaluation/reports_few_shot/.gitkeep

# macOS
.DS_Store
